@page "/"
@rendermode InteractiveServer
@inject WardrobeApiClient ApiClient
@using Markdig

<PageTitle>Home</PageTitle>

<h1>AI Wardrobe Demo</h1>

<div class="btn-group mb-4" role="group" aria-label="Main tabs">
    <button class="btn @(activeTab == "chat" ? "btn-primary" : "btn-outline-primary")" @onclick='@(() => activeTab = "chat")'>Chat</button>
    <button class="btn @(activeTab == "closet" ? "btn-primary" : "btn-outline-primary")" @onclick='@(() => activeTab = "closet")'>Closet</button>
    <button class="btn @(activeTab == "weather" ? "btn-primary" : "btn-outline-primary")" @onclick='@(() => activeTab = "weather")'>Weather</button>
</div>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
	<div class="alert alert-danger">@errorMessage</div>
}

@if (activeTab == "chat")
{
	<section style="display: flex; flex-direction: column; height: calc(100vh - 300px); gap: 1rem;">
		<div class="d-flex justify-content-between align-items-center mb-3">
			<h3>Wardrobe Chat</h3>
			<div class="btn-group" role="group">
				<button class="btn btn-outline-secondary" @onclick="StartNewChatAsync" disabled="@isBusy">New Chat</button>
			</div>
		</div>

		<!-- Chat History -->
		<div class="flex-grow-1 overflow-auto border rounded p-3 mb-3" style="background-color: #f8f9fa;">
			@if (chatMessages.Count == 0)
			{
				<div class="text-center text-muted py-5">
					<p>No messages yet. Start a conversation!</p>
				</div>
			}
			else
			{
				@foreach (var msg in chatMessages)
				{
					<div class="mb-3">
						<div class="mb-1">
							<small class="text-muted">
								<strong>@msg.Author</strong>
								<span class="ms-2">@msg.Timestamp.ToString("HH:mm:ss")</span>
							</small>
						</div>
						@if (msg.RendersMarkdown)
						{
							<div class="p-2 rounded markdown-content @msg.CssClass">
								@((MarkupString)msg.ContentHtml)
							</div>
						}
						else
						{
							<div class="p-2 rounded @msg.CssClass">
								@msg.Content
							</div>
						}
					</div>
				}
			}
		</div>

		<!-- Input Area -->
		<div class="input-group">
			<input 
				type="text" 
				class="form-control" 
				placeholder="Ask for a wardrobe suggestion or provide feedback..." 
				@bind="currentMessage"
				@onkeyup="@(e => e.Key == "Enter" && !isBusy ? SendMessageAsync() : Task.CompletedTask)"
				disabled="@isBusy" />
			<button class="btn btn-primary" @onclick="SendMessageAsync" disabled="@isBusy || string.IsNullOrWhiteSpace(currentMessage)">
				@(isBusy ? "Thinking..." : "Send")
			</button>
			@if (isBusy && !string.IsNullOrWhiteSpace(agentConversationId))
			{
				<button class="btn btn-danger" @onclick="StopChatAsync">
					⊗ Stop
				</button>
			}
		</div>

		@if (!string.IsNullOrWhiteSpace(errorMessage))
		{
			<div class="alert alert-danger mt-2 mb-0">@errorMessage</div>
		}

		@if (!string.IsNullOrWhiteSpace(agentConversationId))
		{
			<small class="text-muted d-block mt-2">
				Thread ID: @(agentConversationId?.Substring(0, Math.Min(12, agentConversationId.Length)) ?? "")...
			</small>
		}
	</section>
}

@if (activeTab == "closet")
{
	<section>
		<div class="d-flex justify-content-between align-items-center mb-3">
			<h3>Closet</h3>
			<button class="btn btn-outline-secondary" @onclick="ResetClosetAsync">Reset Seed Data</button>
		</div>

		<EditForm Model="itemForm" OnValidSubmit="SaveItemAsync">
			<div class="row g-2">
				<div class="col-md-4">
					<label class="form-label">Name</label>
					<InputText class="form-control" @bind-Value="itemForm.Name" />
				</div>
				<div class="col-md-4">
					<label class="form-label">Material</label>
					<InputText class="form-control" @bind-Value="itemForm.Material" />
				</div>
				<div class="col-md-2">
					<label class="form-label">Warmth (1-5)</label>
					<InputNumber class="form-control" @bind-Value="itemForm.Warmth" />
				</div>
				<div class="col-md-2">
					<label class="form-label">Weight</label>
					<InputSelect class="form-select" @bind-Value="itemForm.Weight">
						@foreach (var option in Enum.GetValues<MaterialWeight>())
						{
							<option value="@option">@option</option>
						}
					</InputSelect>
				</div>
			</div>

			<div class="row g-2 mt-1">
				<div class="col-md-4">
					<label class="form-label">Colors (comma separated)</label>
					<InputText class="form-control" @bind-Value="itemForm.ColorsCsv" />
				</div>
				<div class="col-md-4">
					<label class="form-label">Pattern</label>
					<InputText class="form-control" @bind-Value="itemForm.Pattern" />
				</div>
				<div class="col-md-2">
					<label class="form-label">Formality</label>
					<InputSelect class="form-select" @bind-Value="itemForm.Formality">
						@foreach (var option in Enum.GetValues<FormalityLevel>())
						{
							<option value="@option">@option</option>
						}
					</InputSelect>
				</div>
				<div class="col-md-2 d-flex align-items-end">
					<div class="form-check">
						<InputCheckbox class="form-check-input" @bind-Value="itemForm.Waterproof" />
						<label class="form-check-label">Waterproof</label>
					</div>
				</div>
			</div>

			<div class="mt-3 col-md-4 px-0">
				<label class="form-label">Role</label>
				<InputSelect class="form-select" @bind-Value="itemForm.Role">
					@foreach (var role in Enum.GetValues<OutfitRole>())
					{
						<option value="@role">@role</option>
					}
				</InputSelect>
			</div>

			<div class="mt-3 d-flex gap-2">
				<button class="btn btn-primary" disabled="@isBusy">@(!string.IsNullOrWhiteSpace(editingId) ? "Update Item" : "Add Item")</button>
				@if (!string.IsNullOrWhiteSpace(editingId))
				{
					<button class="btn btn-outline-secondary" type="button" @onclick="ClearItemForm">Cancel Edit</button>
				}
			</div>
		</EditForm>

		<table class="table table-striped mt-4">
			<thead>
				<tr>
					<th>Name</th>
					<th>Role</th>
					<th>Colors</th>
					<th>Pattern</th>
					<th></th>
				</tr>
			</thead>
			<tbody>
				@foreach (var item in closetItems)
				{
					<tr>
						<td>@item.Name</td>
						<td>@item.Role</td>
						<td>@string.Join(", ", item.Colors)</td>
						<td>@item.Pattern</td>
						<td class="text-end">
							<button class="btn btn-sm btn-outline-primary me-2" @onclick="() => EditItem(item)">Edit</button>
							<button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteItemAsync(item.Id)">Delete</button>
						</td>
					</tr>
				}
			</tbody>
		</table>
	</section>
}

@if (activeTab == "weather")
{
	<section>
		<div class="d-flex justify-content-between align-items-center mb-3">
			<h3>Forecast</h3>
			<button class="btn btn-outline-secondary" @onclick="ResetForecastAsync">Reset Forecast</button>
		</div>

		<div class="mb-3">
			<label class="form-label">Date</label>
			<InputDate class="form-control" @bind-Value="forecastDate" />
		</div>

		@foreach (var segment in segmentForms)
		{
			<div class="border rounded p-3 mb-2">
				<h5>@segment.Segment</h5>
				<div class="row g-2">
					<div class="col-md-3">
						<label class="form-label">Temperature C</label>
						<InputNumber class="form-control" @bind-Value="segment.TemperatureC" />
					</div>
					<div class="col-md-3">
						<label class="form-label">Precipitation</label>
						<InputSelect class="form-select" @bind-Value="segment.Precipitation">
							@foreach (var option in Enum.GetValues<PrecipitationKind>())
							{
								<option value="@option">@option</option>
							}
						</InputSelect>
					</div>
					<div class="col-md-3 d-flex align-items-end">
						<div class="form-check">
							<InputCheckbox class="form-check-input" @bind-Value="segment.IsSunny" />
							<label class="form-check-label">Sunny</label>
						</div>
					</div>
				</div>
			</div>
		}

		<button class="btn btn-primary" @onclick="SaveForecastAsync" disabled="@isBusy">Save Forecast</button>
	</section>
}

@code {
	private string activeTab = "chat";
	private bool isBusy;
	private string? errorMessage;
	private string? agentConversationId;
	private string currentMessage = string.Empty;
	private readonly List<ChatMessage> chatMessages = [];
	private static readonly MarkdownPipeline MarkdownPipeline = new MarkdownPipelineBuilder()
		.UseAdvancedExtensions()
		.DisableHtml()
		.Build();
	private readonly ClosetItemFormModel itemForm = new();
	private IReadOnlyList<ClosetItemDto> closetItems = [];
	private string? editingId;
	private DateOnly forecastDate = DateOnly.FromDateTime(DateTime.Today);
	private List<SegmentFormModel> segmentForms = [
		new(DaySegment.Morning),
		new(DaySegment.Afternoon),
		new(DaySegment.Evening)
	];

	protected override async Task OnInitializedAsync()
	{
		await ExecuteAsync(async () =>
		{
			await LoadClosetAsync();
			await LoadForecastAsync();
		});
	}

	private async Task SendMessageAsync()
	{
		if (string.IsNullOrWhiteSpace(currentMessage))
		{
			return;
		}

		var userMessage = currentMessage;
		currentMessage = string.Empty;

		await ExecuteAsync(async () =>
		{
			AddChatMessage(ChatMessageKind.User, userMessage);

			await foreach (var streamEvent in ApiClient.StreamAgentLoopAsync(new AgentLoopRequest(
				userMessage,
				ConversationId: agentConversationId,
				MaxToolCalls: 6,
				PageSize: 12)))
			{
				agentConversationId = streamEvent.ConversationId;
				HandleStreamEvent(streamEvent);
				await InvokeAsync(StateHasChanged);
			}
		});
	}

	private async Task StartNewChatAsync()
	{
		await ExecuteAsync(async () =>
		{
			chatMessages.Clear();
			currentMessage = string.Empty;
			agentConversationId = null;
			errorMessage = null;
		});
	}

	private async Task StopChatAsync()
	{
		if (string.IsNullOrWhiteSpace(agentConversationId))
		{
			return;
		}

		await ExecuteAsync(async () =>
		{
			try
			{
				await ApiClient.StopConversationAsync(agentConversationId);
				AddChatMessage(ChatMessageKind.System, "Chat stopped by user.", "System");
			}
			catch (Exception ex)
			{
				errorMessage = $"Failed to stop chat: {ex.Message}";
			}
		});
	}

	private async Task SaveItemAsync()
	{
		await ExecuteAsync(async () =>
		{
			if (!Enum.IsDefined(itemForm.Role))
			{
				throw new InvalidOperationException("Select a role.");
			}

			if (string.IsNullOrWhiteSpace(itemForm.Pattern))
			{
				throw new InvalidOperationException("Pattern is required.");
			}

			var request = new UpsertClosetItemRequest(
				itemForm.Name,
				itemForm.Role,
				SplitCsv(itemForm.ColorsCsv),
				itemForm.Pattern,
				itemForm.Material,
				itemForm.Weight,
				itemForm.Waterproof,
				itemForm.Warmth,
				itemForm.Formality);

			if (!string.IsNullOrWhiteSpace(editingId))
			{
				await ApiClient.UpdateClosetItemAsync(editingId, request);
			}
			else
			{
				await ApiClient.AddClosetItemAsync(request);
			}

			ClearItemForm();
			await LoadClosetAsync();
		});
	}

	private void EditItem(ClosetItemDto item)
	{
		editingId = item.Id;
		itemForm.Name = item.Name;
		itemForm.Material = item.Material;
		itemForm.Role = item.Role;
		itemForm.ColorsCsv = string.Join(", ", item.Colors);
		itemForm.Pattern = item.Pattern;
		itemForm.Weight = item.Weight;
		itemForm.Warmth = item.Warmth;
		itemForm.Waterproof = item.Waterproof;
		itemForm.Formality = item.Formality;
	}

	private async Task DeleteItemAsync(string id)
	{
		await ExecuteAsync(async () =>
		{
			await ApiClient.DeleteClosetItemAsync(id);
			await LoadClosetAsync();
		});
	}

	private async Task ResetClosetAsync()
	{
		await ExecuteAsync(async () =>
		{
			await ApiClient.ResetClosetAsync();
			ClearItemForm();
			await LoadClosetAsync();
		});
	}

	private async Task SaveForecastAsync()
	{
		await ExecuteAsync(async () =>
		{
			var request = new UpdateForecastRequest(
				forecastDate,
				segmentForms.Select(s => new SegmentForecastDto(s.Segment, s.TemperatureC, s.Precipitation, s.IsSunny)).ToArray());

			await ApiClient.UpdateForecastAsync(request);
			await LoadForecastAsync();
		});
	}

	private async Task ResetForecastAsync()
	{
		await ExecuteAsync(async () =>
		{
			await ApiClient.ResetForecastAsync();
			await LoadForecastAsync();
		});
	}

	private async Task LoadClosetAsync() =>
		closetItems = await ApiClient.GetClosetItemsAsync();

	private async Task LoadForecastAsync()
	{
		var forecast = await ApiClient.GetForecastAsync();
		if (forecast is null)
		{
			return;
		}

		forecastDate = forecast.Date;
		segmentForms = forecast.Segments
			.OrderBy(s => s.Segment)
			.Select(s => new SegmentFormModel(s.Segment)
			{
				TemperatureC = s.TemperatureC,
				Precipitation = s.Precipitation,
				IsSunny = s.IsSunny
			})
			.ToList();
	}

	private async Task ExecuteAsync(Func<Task> action)
	{
		errorMessage = null;
		isBusy = true;
		try
		{
			await action();
		}
		catch (Exception ex)
		{
			errorMessage = ex.Message;
		}
		finally
		{
			isBusy = false;
		}
	}

	private void ClearItemForm()
	{
		editingId = null;
		itemForm.Name = string.Empty;
		itemForm.Material = string.Empty;
		itemForm.ColorsCsv = string.Empty;
		itemForm.Pattern = "solid";
		itemForm.Waterproof = false;
		itemForm.Warmth = 3;
		itemForm.Weight = MaterialWeight.Medium;
		itemForm.Formality = FormalityLevel.Casual;
		itemForm.Role = OutfitRole.Top;
	}

	private static List<string> SplitCsv(string value) =>
		value.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
			.Select(x => x.ToLowerInvariant())
			.Distinct()
			.ToList();

	private string ResolveCandidateItemName(string? itemId)
	{
		if (string.IsNullOrWhiteSpace(itemId))
		{
			return "(not selected)";
		}

		var item = closetItems.FirstOrDefault(x => x.Id == itemId);
		return item is null ? $"Unknown item ({itemId})" : item.Name;
	}

	private static string DisplayItem(ClosetItemDto? item) => item?.Name ?? "(not selected)";

	private void HandleStreamEvent(AgentLoopStreamEvent streamEvent)
	{
		switch (streamEvent.EventType)
		{
			case AgentLoopEventType.Status:
				AddChatMessage(ChatMessageKind.Workflow, streamEvent.Message, "Workflow");
				break;
			case AgentLoopEventType.Lifecycle:
				AddChatMessage(ChatMessageKind.Workflow, streamEvent.Message, "Workflow");
				break;
			case AgentLoopEventType.AgentDelta:
				AddChatMessage(ChatMessageKind.Workflow, $"{ResolveAgentAuthor(streamEvent.Agent)} streaming: {streamEvent.Message}", "Workflow");
				break;
			case AgentLoopEventType.Tool:
				AddChatMessage(ChatMessageKind.Workflow, $"{streamEvent.Agent ?? streamEvent.Executor} used {streamEvent.Tool}: {streamEvent.Message}", "Workflow");
				break;
			case AgentLoopEventType.Validation:
				AddChatMessage(ChatMessageKind.Workflow, $"Validation: {streamEvent.Message}", "Workflow");
				break;
			case AgentLoopEventType.Summary:
				AddChatMessage(ChatMessageKind.Workflow, streamEvent.Message, "Context");
				break;
			case AgentLoopEventType.Debug:
				AddChatMessage(ChatMessageKind.Workflow, $"Debug: {streamEvent.Message}", "Workflow");
				break;
			case AgentLoopEventType.AgentMessage:
				AddChatMessage(ChatMessageKind.Agent, streamEvent.Message, ResolveAgentAuthor(streamEvent.Agent));
				break;
			case AgentLoopEventType.Complete:
				if (streamEvent.Response is null)
				{
					throw new InvalidOperationException("Streaming workflow finished without a final response.");
				}

				AddChatMessage(
					ChatMessageKind.Agent,
					streamEvent.Response.AgentResponse,
					"✅ Conclusion");
				break;
			case AgentLoopEventType.Error:
				throw new InvalidOperationException(streamEvent.Message);
		}
	}

	private void AddChatMessage(ChatMessageKind kind, string content, string? author = null)
	{
		chatMessages.Add(new ChatMessage
		{
			Kind = kind,
			Author = author ?? ResolveAuthor(kind),
			Content = content,
			ContentHtml = kind is ChatMessageKind.User ? string.Empty : Markdown.ToHtml(content, MarkdownPipeline),
			Timestamp = DateTime.Now
		});
	}

	private static string ResolveAuthor(ChatMessageKind kind) => kind switch
	{
		ChatMessageKind.User => "👤 You",
		ChatMessageKind.Agent => "🤖 Agent",
		_ => "Workflow"
	};

	private static string ResolveAgentAuthor(string? agent) => agent switch
	{
		"weather-agent" => "🌤 Weather Agent",
		"WeatherExecutor" => "🌤 Weather Agent",
		"stylist-agent" => "👗 Stylist Agent",
		"StylistExecutor" => "👗 Stylist Agent",
		_ => "🤖 Agent"
	};

	private sealed class ChatMessage
	{
		public ChatMessageKind Kind { get; set; }
		public string Author { get; set; } = string.Empty;
		public string Content { get; set; } = string.Empty;
		public string ContentHtml { get; set; } = string.Empty;
		public DateTime Timestamp { get; set; }
		public bool RendersMarkdown => Kind is not ChatMessageKind.User;
		public string CssClass => Kind switch
		{
			ChatMessageKind.User => "bg-primary text-white",
			ChatMessageKind.Agent => "bg-light",
			ChatMessageKind.System => "bg-info text-white",
			_ => "bg-warning-subtle border"
		};
	}

	private enum ChatMessageKind
	{
		User,
		Agent,
		Workflow,
		System
	}

	private sealed class ClosetItemFormModel
	{
		public string Name { get; set; } = string.Empty;
		public string Material { get; set; } = string.Empty;
		public string ColorsCsv { get; set; } = string.Empty;
		public string Pattern { get; set; } = "solid";
		public MaterialWeight Weight { get; set; } = MaterialWeight.Medium;
		public FormalityLevel Formality { get; set; } = FormalityLevel.Casual;
		public bool Waterproof { get; set; }
		public int Warmth { get; set; } = 3;
		public OutfitRole Role { get; set; } = OutfitRole.Top;
	}

	private sealed class SegmentFormModel(DaySegment segment)
	{
		public DaySegment Segment { get; } = segment;
		public int TemperatureC { get; set; }
		public PrecipitationKind Precipitation { get; set; }
		public bool IsSunny { get; set; }
	}
}
